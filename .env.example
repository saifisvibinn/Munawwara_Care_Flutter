# Munawwara Care — environment template
# Copy to `.env` in this directory (.env is gitignored).
# NOT bundled in release builds — load at dev time with:
#   flutter run --dart-define-from-file=.env

# ── Backend API (REQUIRED) ────────────────────────────────────────────────────
API_BASE_URL=https://your-api.example.com/api

# Android emulator — reach host machine (optional):
# API_ANDROID_HOST=10.0.2.2

# Socket.IO origin (scheme + host + port, NO /api). Unset = same host as API.
# SOCKET_BASE_URL=https://your-realtime.example.com

# ── Agora RTC (voice calls — required for calls) ─────────────────────────────
AGORA_APP_ID=

# ── UmmahAPI (Islamic Corner prayer times, etc.) ────────────────────────────
UMMAH_API_KEY=

# ── Google Maps ─────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

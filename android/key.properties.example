# Copy to android/key.properties and fill in real values.
# Never commit key.properties or your keystore file.
#
# Put the .jks file in android/app/ unless you use an absolute storeFile path.
#
# Create a keystore (example; adjust paths for your OS):
#   keytool -genkey -v -keystore android/app/upload-keystore.jks
#     -keyalg RSA -keysize 2048 -validity 10000 -alias upload
#
# Paths for storeFile are relative to the android/app/ directory.
storePassword=your-store-password
keyPassword=your-key-password
keyAlias=upload
storeFile=upload-keystore.jks
